# MongoDB Connection String (recommended)
# Supports mongodb:// and mongodb+srv:// protocols
# Database name is extracted from the connection string path
MONGODB_CONNECTION_STRING='mongodb://localhost:27017/mydb'

# Alternative: Simple URI format (legacy)
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=mydb

# Or individual settings (used if connection string is not set)
# MONGO_HOST=localhost
# MONGO_PORT=27017
# MONGO_USER=
# MONGO_PASSWORD=
# MONGO_AUTH_DB=admin
# MONGO_DB=mydb
