{
  "name": "@deniscuciuc/mongo-analyzer",
  "version": "1.0.0",
  "description": "CLI tool that analyzes MongoDB databases - index usage, slow queries, schema issues, fragmentation and replica-set health.",
  "keywords": [
    "mongodb",
    "mongo",
    "database",
    "analyzer",
    "performance",
    "cli",
    "indexes",
    "atlas",
    "replica-set",
    "schema"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deniscuciuc/db-analyzer-mongo.git"
  },
  "bugs": {
    "url": "https://github.com/deniscuciuc/db-analyzer-mongo/issues"
  },
  "license": "MIT",
  "author": "Denis Cuciuc <denis@deniscuciuc.dev>",
  "homepage": "https://github.com/deniscuciuc/db-analyzer-mongo#readme",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mongo-analyzer": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "analyzerrc.example.json"
  ],
  "scripts": {
    "start": "node --env-file=.env -r ts-node/register index.ts start",
    "analyze": "node --env-file=.env -r ts-node/register index.ts",
    "analyze:help": "node -r ts-node/register index.ts --help",
    "analyze:health": "node --env-file=.env -r ts-node/register index.ts -j -c health",
    "analyze:indexes": "node --env-file=.env -r ts-node/register index.ts -j -c unused-indexes",
    "analyze:queries": "node --env-file=.env -r ts-node/register index.ts -j -c slow-queries",
    "analyze:html": "node --env-file=.env -r ts-node/register index.ts --html -c full",
    "analyze:watch": "node --env-file=.env -r ts-node/register index.ts -c health --watch 30",
    "compact": "node --env-file=.env -r ts-node/register index.ts -c run-compact",
    "compact:check": "node --env-file=.env -r ts-node/register index.ts -j -c compact-needed",
    "profiler:enable": "node --env-file=.env -r ts-node/register index.ts -j -c enable-profiler",
    "profiler:disable": "node --env-file=.env -r ts-node/register index.ts -j -c disable-profiler",
    "build": "tsc",
    "postbuild": "node scripts/add-shebang.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "pnpm lint && pnpm build",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.1.0",
    "mongodb": "^6.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^22.15.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  }
}
